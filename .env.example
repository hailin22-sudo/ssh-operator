# 服务器连接信息（必填）
SSH_HOST=1.2.3.4
SSH_PORT=22
SSH_USER=root

# 密码登录（二选一）
SSH_PASS=your-password

# 密钥登录（二选一，推荐）
# SSH_KEY_PATH=/path/to/private_key

# 部署相关路径
REMOTE_ROOT=/www/wwwroot/your-project
BACKUP_DIR=/www/backup
LOCAL_LOG_DIR=./logs

# 博客发布配置（可选）
BLOG_API_URL=https://your-blog.com
BLOG_USERNAME=admin
BLOG_PASSWORD=your-password
# Ghost 用 Admin API Key，格式：<id>:<secret>
BLOG_API_KEY=your-integration-key
